APP_NAME=CareSync
APP_ENV=production
APP_HOST=0.0.0.0
BRAIN_GATEWAY_MODE=direct
OCR_CONFIDENCE_THRESHOLD=0.85
ACUTE_CONDITION_LOOKBACK_DAYS=180

GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
ADK_MODEL=gemini-2.5-flash

DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
CORS_ORIGINS=https://your-frontend-url.run.app

GOOGLE_DRIVE_CLASSIFICATION_ENABLED=true
GOOGLE_CALENDAR_ID=your-calendar-id
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

OPENFDA_API_KEY=your-openfda-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
USE_SYNTHETIC_MAPS=false

BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_ID=caresync
BIGQUERY_TABLE_ID=integration_events

MEDICAL_MODEL_BACKEND=placeholder
MEDGEMMA_MODEL_ID=google/medgemma-1.5-4b-it
MEDSIGLIP_MODEL_ID=google/medsiglip-448
